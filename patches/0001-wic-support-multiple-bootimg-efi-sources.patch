From b1d33f57faaef78f413d8de596d1f97e50e78122 Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Mathieu=20Dupr=C3=A9?= <mathieu.dupre@savoirfairelinux.com>
Date: Mon, 23 Mar 2026 11:08:16 +0100
Subject: [PATCH] wic: support multiple bootimg-efi sources

Generate a random temporary partition file name when using the
bootimg-efi plugin to allow multiple bootimg-efi sources.

Signed-off-by: Paul Le Guen de Kerneizon <paul.leguendekerneizon@savoirfairelinux.com>
---
 scripts/lib/wic/plugins/source/bootimg_efi.py | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py b/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py
index 430b0a4b02..b0c5c65e4c 100644
--- a/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py
+++ b/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py
@@ -15,6 +15,7 @@ import os
 import tempfile
 import shutil
 import re
+import uuid

 from glob import glob

@@ -411,7 +412,7 @@ class BootimgEFIPlugin(SourcePlugin):
                      part.mountpoint, blocks)

         # dosfs image, created by mkdosfs
-        bootimg = "%s/boot.img" % cr_workdir
+        bootimg = "%s/boot_%s.img" % (cr_workdir, uuid.uuid4())

         label = part.label if part.label else "ESP"

--
2.34.1
