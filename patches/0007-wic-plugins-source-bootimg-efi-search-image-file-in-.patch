From 4fa244674ba60048efd17c58de62ceaf8f1f15ee Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Mathieu=20Dupr=C3=A9?= <mathieu.dupre@savoirfairelinux.com>
Date: Mon, 23 Mar 2026 13:53:15 +0100
Subject: [PATCH] wic/plugins/source/bootimg-efi: search image file in
 IMGDEPLOYDIR
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

It is possible that some images are not copy inside the DEPLOY_DIR_IMAGE
when wic is called. Also search these images inside IMGDEPLOYDIR.

Signed-off-by: Mathieu Dupré <mathieu.dupre@savoirfairelinux.com>
Signed-off-by: Paul Le Guen de Kerneizon <paul.leguendekerneizon@savoirfairelinux.com>
---
 scripts/lib/wic/plugins/source/bootimg_efi.py | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py b/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py
index 430b0a4b02..42e66e86e4 100644
--- a/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py
+++ b/sources/poky/scripts/lib/wic/plugins/source/bootimg_efi.py
@@ -41,9 +41,15 @@ class BootimgEFIPlugin(SourcePlugin):
             raise WicError("Couldn't find DEPLOY_DIR_IMAGE, exiting")

         if initrd:
+            tmp_bootimg_dir = get_bitbake_var("IMGDEPLOYDIR")
+            if not tmp_bootimg_dir:
+                raise WicError("Couldn't find IMGDEPLOYDIR, exiting")
             initrds = initrd.split(';')
             for rd in initrds:
-                cp_cmd = "cp -v -p %s/%s %s" % (bootimg_dir, rd, hdddir)
+                full_rd = os.path.join(bootimg_dir, rd)
+                if not os.path.exists(full_rd):
+                    full_rd = os.path.join(tmp_bootimg_dir, rd)
+                cp_cmd = "cp %s %s" % (full_rd, hdddir)
                 out = exec_cmd(cp_cmd, True)
                 logger.debug("initrd files:\n%s" % (out))
         else:
--
2.34.1
